{
  "title": "CosyVoice3 TTS Runpod",
  "description": "CosyVoice3 TTS for serverless inference",
  "type": "serverless",
  "category": "audio",
  "iconUrl": "https://avatars.githubusercontent.com/u/121991246",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 60,
    "gpuIds": "AMPERE_24",
    "presets": [
      {
        "name": "tts",
        "defaults": {
          "tts_text": "안녕하세요, 반갑습니다.",
          "instruct_text": "You are a helpful assistant.<|endofprompt|>",
          "prompt_wav_b64": "base64 encoded wav file"
        }
      }
    ],
    "env": [
      {
        "key": "HF_HOME",
        "value": "/workspace/hf"
      },
      {
        "key": "MODELSCOPE_CACHE",
        "value": "/workspace/modelscope"
      }
    ]
  }
}
